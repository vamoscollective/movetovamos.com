{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "movetovamos",
  "compatibility_date": "2026-07-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    "movetovamos.com/*",
    "www.movetovamos.com/*"
  ]
}
